{
  "name": "threadpick-inventory",
  "version": "0.1.0",
  "description": "古着商品の登録、画像確認、採寸、店頭販売、売却済み管理を行うための MVP プロジェクトです。",
  "private": true,
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
